# Zoe Assistant — Environment Variables
# انسخ هذا الملف إلى .env وعبّئ القيم

# ─── Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
BOT_USERNAME=

# ─── Database ─────────────────────────────────────
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# ─── DeepSeek AI ──────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_API_URL=https://api.deepseek.com

# ─── App ──────────────────────────────────────────
APP_URL=https://zoe.yourdomain.com
APP_NAME=Zoe Assistant

# ─── Zoe Personality (اختياري) ────────────────────
ZOE_SYSTEM_PROMPT=
